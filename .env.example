ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL — SQLAlchemy URL format:
# postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/sdm_dss

SECRET_KEY=change-me-to-a-long-random-string

# Set true to sync tables on app startup (after first setup, false is fine)
DB_INIT_ON_STARTUP=true
